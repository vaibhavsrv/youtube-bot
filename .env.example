# =================================================================
# YouTube Bot Environment Configuration
# =================================================================
# Copy this file to .env and fill in the values.

# --- Groq (Required for Script Generation) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Image Generation (DeAPI.ai) ---
DEAPI_TOKEN=your_deapi_token_here
# Optional: Model for image generation
DEAPI_MODEL=Flux_2_Klein_4B_BF16
# Image dimensions
DEAPI_IMAGE_WIDTH=768
DEAPI_IMAGE_HEIGHT=768
# Seconds to wait between image requests to avoid rate limits
DEAPI_COOLDOWN=10
# Global negative prompt to append to all image requests
IMAGE_NEGATIVE_PROMPT=

# --- TTS (Edge TTS - no API key needed) ---
# Default voice for Edge TTS if not specified in channel presets
EDGE_TTS_VOICE=en-US-ChristopherNeural

# --- TTS (ElevenLabs - optional alternative) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVEN_STABILITY=0.5
ELEVEN_SIMILARITY=0.75

# --- YouTube Upload (OAuth2) ---
#
# LOCAL DEVELOPMENT:
# Point to your client_secret.json and youtube_token.json files.
# If these aren't set, it defaults to secrets/ directory.
YT_CLIENT_SECRET=secrets/client_secret.json
YT_TOKEN=secrets/youtube_token.json

# CI/CD (GitHub Actions):
# These are used to reconstruct credentials from environment variables.
YT_CLIENT_ID=
YT_CLIENT_SECRET_VALUE=
# Default refresh token
YT_REFRESH_TOKEN=

# CHANNEL-SPECIFIC REFRESH TOKENS:
# Used by specific channel presets (see pipeline/channel_presets.py)
YT_REFRESH_TOKEN_HI=
YT_REFRESH_TOKEN_EN=
YT_REFRESH_TOKEN_MYTH=
YT_REFRESH_TOKEN_MYTH_2=

# --- Miscellaneous ---
# Override the topic hint for the next run (useful for testing)
SHORT_TOPIC=

# These are used by the test script which may be using an older HF/Pollinations flow.
HF_TOKEN=
HF_NO_POLLINATIONS=
HF_IMAGE_WIDTH=512
HF_IMAGE_HEIGHT=512
HF_NEGATIVE_PROMPT=
HF_CONCURRENCY=2
